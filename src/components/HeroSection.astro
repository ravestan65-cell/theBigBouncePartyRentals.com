---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero">
  <div class="hero__slide">
    <img
      src="https://files.sysers.com/cp/upload/highfivepartyrentals/gallery/img_banner_1_highfivepartyrentals.jpg"
      alt="Kids having fun on colorful bounce houses at a party"
      class="hero__bg-image"
      loading="eager"
    />
    <div class="hero__overlay"></div>
    <div class="hero__content-wrap">
      <div class="hero__content">
        <span class="hero__tag">America's #1 Party Rental Company</span>
        <h1 class="hero__title">
          Premium Bounce Houses<br/>& Party Rentals
        </h1>
        <p class="hero__subtitle">
          Professionally sanitized & shipped same day across the USA for your next event.
        </p>
        <div class="hero__actions">
          <a href="/products" class="btn btn--primary btn--lg">Shop Rentals</a>
          <a href="/contact" class="btn btn--secondary btn--lg">Get a Quote</a>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__trust-strip">
    <div class="hero__trust-inner">
      <div class="hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span><strong>500+</strong> Happy Families</span>
      </div>
      <div class="hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span><strong>1000+</strong> Events</span>
      </div>
      <div class="hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        <span><strong>5-Star</strong> Rating</span>
      </div>
      <div class="hero__trust-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span><strong>On-Time</strong> Guaranteed</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    width: 100%;
  }

  .hero__slide {
    position: relative;
    width: 100%;
    height: 480px;
    overflow: hidden;
  }

  .hero__bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.05) 100%);
    z-index: 1;
  }

  .hero__content-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    z-index: 2;
  }

  .hero__content {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero__tag {
    display: inline-block;
    background: var(--color-secondary);
    color: var(--color-text);
    font-weight: 800;
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    border-radius: 3px;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-heading);
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 1rem;
    color: white;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    max-width: 550px;
  }

  .hero__subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
    margin-bottom: 1.5rem;
    max-width: 460px;
  }

  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Trust strip */
  .hero__trust-strip {
    width: 100%;
    background: var(--color-primary);
  }
  .hero__trust-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    padding: 0.75rem 1.5rem;
    flex-wrap: wrap;
  }
  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: white;
    font-size: 0.8rem;
  }
  .hero__trust-item strong {
    font-weight: 800;
  }

  @media (max-width: 768px) {
    .hero__slide {
      height: 380px;
    }
    .hero__overlay {
      background: rgba(0,0,0,0.5);
    }
    .hero__content {
      text-align: center;
    }
    .hero__title {
      max-width: 100%;
    }
    .hero__subtitle {
      max-width: 100%;
    }
    .hero__actions {
      justify-content: center;
    }
    .hero__trust-inner {
      gap: 1rem;
      padding: 0.6rem 1rem;
    }
    .hero__trust-item {
      font-size: 0.7rem;
    }
  }
  @media (max-width: 480px) {
    .hero__slide {
      height: 320px;
    }
    .hero__tag {
      font-size: 0.65rem;
      padding: 0.25rem 0.6rem;
      margin-bottom: 0.75rem;
    }
    .hero__title {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .hero__subtitle {
      font-size: 0.88rem;
      margin-bottom: 1rem;
    }
    .hero__actions {
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
    }
    .hero__actions .btn {
      width: 100%;
      max-width: 280px;
    }
    .hero__trust-inner {
      gap: 0.6rem;
      padding: 0.5rem 0.5rem;
    }
    .hero__trust-item {
      font-size: 0.6rem;
      gap: 0.25rem;
    }
    .hero__trust-item svg {
      width: 14px;
      height: 14px;
    }
  }
  @media (max-width: 375px) {
    .hero__slide {
      height: 300px;
    }
    .hero__title {
      font-size: 1.3rem;
    }
    .hero__trust-item {
      font-size: 0.55rem;
    }
  }
</style>
