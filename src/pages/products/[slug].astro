---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProducts, getProductBySlug, getPrimaryImage, getCategoryLabel, getCategorySlug, getFullRentalPrice, getReservationPrice, getBalanceDueOnDelivery } from '../../lib/supabase';
import '../../styles/global.css';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const allProducts = await getProducts();
const categoryLabel = getCategoryLabel(product);
const categorySlug = getCategorySlug(product);
const primaryImage = getPrimaryImage(product);

const related = allProducts
  .filter(p => p.category?.slug === categorySlug && p.id !== product.id)
  .slice(0, 3);

const fullRentalPrice = getFullRentalPrice(product);
const reservationPrice = getReservationPrice(product);
const balanceDue = getBalanceDueOnDelivery(product);

const FORMSPARK_ACTION = "https://submit-form.com/kJ4y3Vadl";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "sku": product.sku,
  "image": primaryImage?.url,
  "brand": { "@type": "Brand", "name": "The Big Bounce Party Rentals" },
  "offers": [
    {
      "@type": "Offer",
      "name": "Daily Rental",
      "price": fullRentalPrice,
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "priceValidUntil": "2027-12-31"
    },
    {
      "@type": "Offer",
      "name": "Buy New",
      "price": product.buy_price,
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "priceValidUntil": "2027-12-31"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "47",
    "bestRating": "5"
  }
};
---

<Layout title={product.name} description={product.short_description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Breadcrumb -->
  <section class="pdp-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href={`/products#${categorySlug}`}>{categoryLabel}</a>
        <span>/</span>
        <span>{product.name}</span>
      </nav>
    </div>
  </section>

  <!-- Product Detail -->
  <section class="pdp">
    <div class="container pdp__inner">
      <!-- Image Gallery -->
      <div class="pdp__gallery">
        {product.images && product.images.length > 0 ? (
          <>
            <div class="pdp__gallery-main">
              {product.badge && <span class="badge pdp__badge">{product.badge}</span>}
              <img
                class="pdp__main-image"
                id="mainImage"
                src={primaryImage?.url}
                alt={primaryImage?.alt || product.name}
                width="600"
                height="450"
              />
            </div>
            {product.images.length > 1 && (
              <div class="pdp__thumbnails">
                {product.images.map((img: any, i: number) => (
                  <button
                    class={`pdp__thumb ${i === 0 ? 'pdp__thumb--active' : ''}`}
                    data-src={img.url}
                    data-alt={img.alt}
                  >
                    <img src={img.url} alt={img.alt || `${product.name} view ${i + 1}`} loading="lazy" width="80" height="60" />
                  </button>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="pdp__image-main" data-category={categorySlug}>
            {product.badge && <span class="badge pdp__badge">{product.badge}</span>}
            <span class="pdp__image-label">{categoryLabel}</span>
          </div>
        )}
      </div>

      <!-- Info Column -->
      <div class="pdp__info">
        <div class="pdp__category-tag">
          <span class="badge badge--primary">{categoryLabel}</span>
          {product.badge && <span class="badge">{product.badge}</span>}
        </div>

        <h1 class="pdp__title">{product.name}</h1>

        <div class="pdp__rating">
          <span class="pdp__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="pdp__rating-text">5.0 (47 reviews)</span>
          <span class="pdp__sku">SKU: {product.sku}</span>
        </div>

        <p class="pdp__description">{product.short_description}</p>

        <!-- Availability Banner -->
        <div class="pdp__availability">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          <span>Available for <strong>rent</strong> & <strong>purchase</strong> — Ships nationwide with same-day dispatch</span>
        </div>

        <!-- Pricing Cards — Buy New and Rental -->
        <div class="pdp__pricing">
          <div class="pdp__price-card pdp__price-card--rental">
            <div class="pdp__price-card-header">Daily Rental</div>
            <div class="pdp__price-card-amount">
              <span class="pdp__price-value">${fullRentalPrice}</span>
              <span class="pdp__price-period">/day</span>
            </div>
            <div class="pdp__reserve-breakdown">
              <div class="pdp__reserve-row pdp__reserve-row--now">
                <span class="pdp__reserve-label">Reserve now</span>
                <span class="pdp__reserve-amount">${reservationPrice}</span>
              </div>
              <div class="pdp__reserve-row">
                <span class="pdp__reserve-label">Balance on delivery</span>
                <span class="pdp__reserve-amount">${balanceDue}</span>
              </div>
            </div>
            <ul class="pdp__price-perks">
              <li>Free delivery & setup</li>
              <li>Professional sanitization</li>
              <li>Same-day pickup included</li>
            </ul>
            <button type="button" class="btn btn--primary btn--full" id="openReserve">Reserve Now — ${reservationPrice}</button>
          </div>

          <div class="pdp__price-card pdp__price-card--buy">
            <div class="pdp__price-card-header">Buy New</div>
            <div class="pdp__price-card-amount">
              <span class="pdp__price-value">${product.buy_price}</span>
            </div>
            <ul class="pdp__price-perks">
              <li>Brand new, factory sealed</li>
              <li>Full warranty included</li>
              <li>Keep it forever</li>
            </ul>
            <a href="/contact" class="btn btn--secondary btn--full">Buy Now — ${product.buy_price}</a>
          </div>
        </div>

        <!-- Quick Contact -->
        <div class="pdp__quick-contact">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>Questions? Email <a href="mailto:info@thebigbouncepartyrentals.com"><strong>info@thebigbouncepartyrentals.com</strong></a> — We respond within 2 hours!</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Specs & Features -->
  <section class="section section--alt pdp-details">
    <div class="container">
      <div class="pdp-details__grid">
        <div class="pdp-details__section">
          <h2 class="pdp-details__heading">Specifications</h2>
          <div class="specs-table">
            <div class="specs-table__row"><span class="specs-table__label">Dimensions</span><span class="specs-table__value">{product.dimensions}</span></div>
            <div class="specs-table__row"><span class="specs-table__label">Length</span><span class="specs-table__value">{product.length}</span></div>
            <div class="specs-table__row"><span class="specs-table__label">Width</span><span class="specs-table__value">{product.width}</span></div>
            <div class="specs-table__row"><span class="specs-table__label">Height</span><span class="specs-table__value">{product.height}</span></div>
            {product.weight && <div class="specs-table__row"><span class="specs-table__label">Weight</span><span class="specs-table__value">{product.weight}</span></div>}
            <div class="specs-table__row"><span class="specs-table__label">Age Range</span><span class="specs-table__value">{product.age_range}</span></div>
            <div class="specs-table__row"><span class="specs-table__label">Capacity</span><span class="specs-table__value">{product.capacity}</span></div>
            <div class="specs-table__row"><span class="specs-table__label">SKU</span><span class="specs-table__value">{product.sku}</span></div>
          </div>
        </div>

        <div class="pdp-details__section">
          <h2 class="pdp-details__heading">Features</h2>
          <ul class="features-list">
            {product.features.map((feature: string) => (
              <li class="features-list__item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="pdp-details__section">
          <h2 class="pdp-details__heading">What's Included</h2>
          <ul class="included-list">
            {product.included_items.map((item: string) => (
              <li class="included-list__item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Description -->
  <section class="section pdp-description">
    <div class="container">
      <h2 class="section-title">About This Product</h2>
      <div class="pdp-description__content">
        <p>{product.description}</p>
      </div>
    </div>
  </section>

  <!-- Customer Reviews -->
  <section class="section section--alt pdp-reviews">
    <div class="container">
      <h2 class="section-title">Customer Reviews</h2>
      <div class="reviews__layout">
        <!-- Rating Summary -->
        <div class="reviews__summary">
          <div class="reviews__summary-card">
            <div class="reviews__avg">4.9</div>
            <div class="reviews__avg-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <div class="reviews__count">Based on 47 reviews</div>
            <div class="reviews__bars">
              <div class="reviews__bar-row"><span class="reviews__bar-label">5 star</span><div class="reviews__bar-track"><div class="reviews__bar-fill" style="width:89%"></div></div><span class="reviews__bar-pct">89%</span></div>
              <div class="reviews__bar-row"><span class="reviews__bar-label">4 star</span><div class="reviews__bar-track"><div class="reviews__bar-fill" style="width:9%"></div></div><span class="reviews__bar-pct">9%</span></div>
              <div class="reviews__bar-row"><span class="reviews__bar-label">3 star</span><div class="reviews__bar-track"><div class="reviews__bar-fill" style="width:2%"></div></div><span class="reviews__bar-pct">2%</span></div>
              <div class="reviews__bar-row"><span class="reviews__bar-label">2 star</span><div class="reviews__bar-track"><div class="reviews__bar-fill" style="width:0%"></div></div><span class="reviews__bar-pct">0%</span></div>
              <div class="reviews__bar-row"><span class="reviews__bar-label">1 star</span><div class="reviews__bar-track"><div class="reviews__bar-fill" style="width:0%"></div></div><span class="reviews__bar-pct">0%</span></div>
            </div>
          </div>

          <!-- Leave Review Form -->
          <div class="reviews__form-card">
            <h3 class="reviews__form-title">Leave Your Review</h3>
            <form class="reviews__form" id="reviewForm" action={FORMSPARK_ACTION} method="POST">
              <input type="hidden" name="_subject" value={`Product review — ${product.name}`} />
              <input type="hidden" name="product" value={product.name} />
              <input type="hidden" name="sku" value={product.sku} />
              <input type="hidden" name="rating" id="reviewRating" value="" />
              <input type="hidden" name="product_url" id="reviewProductUrl" />
              <div class="reviews__form-row">
                <div class="reviews__form-field">
                  <label class="reviews__form-label" for="reviewName">Name</label>
                  <input type="text" id="reviewName" name="name" class="reviews__form-input" placeholder="Your name" required />
                </div>
                <div class="reviews__form-field">
                  <label class="reviews__form-label" for="reviewEmail">Email</label>
                  <input type="email" id="reviewEmail" name="email" class="reviews__form-input" placeholder="Your email" required />
                </div>
              </div>
              <div class="reviews__form-field">
                <label class="reviews__form-label">Rating</label>
                <div class="reviews__form-stars">
                  <span class="reviews__form-star" data-rating="1">&#9734;</span>
                  <span class="reviews__form-star" data-rating="2">&#9734;</span>
                  <span class="reviews__form-star" data-rating="3">&#9734;</span>
                  <span class="reviews__form-star" data-rating="4">&#9734;</span>
                  <span class="reviews__form-star" data-rating="5">&#9734;</span>
                </div>
              </div>
              <div class="reviews__form-field">
                <label class="reviews__form-label" for="reviewText">Your Review</label>
                <textarea id="reviewText" name="review" class="reviews__form-input reviews__form-textarea" placeholder="Share your experience..." rows="4" required></textarea>
              </div>
              <button type="submit" class="btn btn--primary">Submit Review</button>
              <p class="reviews__form-status" id="reviewStatus" role="status" aria-live="polite" hidden></p>
            </form>
          </div>
        </div>

        <!-- Review Cards -->
        <div class="reviews__list">
          <div class="reviews__card">
            <div class="reviews__card-header">
              <span class="reviews__card-name">S****a</span>
              <span class="reviews__card-date">Mar 8, 2026</span>
            </div>
            <div class="reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="reviews__card-text">We rented this for my son's birthday party and the kids had an absolute blast! Setup was super quick and the quality is fantastic. Will definitely be ordering again for our next event.</p>
            <div class="reviews__card-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              <span>Verified Buyer</span>
            </div>
          </div>
          <div class="reviews__card">
            <div class="reviews__card-header">
              <span class="reviews__card-name">M****l</span>
              <span class="reviews__card-date">Feb 22, 2026</span>
            </div>
            <div class="reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="reviews__card-text">Purchased this for our rental business and the quality exceeded expectations. Customers love it and it holds up great event after event. Shipping was fast too!</p>
            <div class="reviews__card-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              <span>Verified Buyer</span>
            </div>
          </div>
          <div class="reviews__card">
            <div class="reviews__card-header">
              <span class="reviews__card-name">J****n</span>
              <span class="reviews__card-date">Feb 10, 2026</span>
            </div>
            <div class="reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
            <p class="reviews__card-text">Great product, very durable and well-made. The kids at our church event loved it. Only wish the instructions were a little more detailed, but setup was still pretty straightforward.</p>
            <div class="reviews__card-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              <span>Verified Buyer</span>
            </div>
          </div>
          <div class="reviews__card">
            <div class="reviews__card-header">
              <span class="reviews__card-name">A****e</span>
              <span class="reviews__card-date">Jan 28, 2026</span>
            </div>
            <div class="reviews__card-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="reviews__card-text">This was a huge hit at our neighborhood block party! Easy to inflate, very sturdy, and the colors are vibrant. Delivery was right on time. Highly recommend The Big Bounce Party Rentals!</p>
            <div class="reviews__card-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              <span>Verified Buyer</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Safety Banner -->
  <section class="safety-banner">
    <div class="container safety-banner__inner">
      <div class="safety-banner__item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span>Safety Inspected</span>
      </div>
      <div class="safety-banner__item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span>Fully Insured</span>
      </div>
      <div class="safety-banner__item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3"/></svg>
        <span>Hospital-Grade Clean</span>
      </div>
      <div class="safety-banner__item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>On-Time Delivery</span>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="section related">
      <div class="container">
        <h2 class="section-title">You Might Also Like</h2>
        <p class="section-subtitle">Other popular items in {categoryLabel}</p>
        <div class="related__grid">
          {related.map(p => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Reserve Now Modal -->
  <div class="reserve-modal" id="reserveModal" hidden>
    <div class="reserve-modal__overlay" data-reserve-close></div>
    <div class="reserve-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="reserveModalTitle">
      <button type="button" class="reserve-modal__close" data-reserve-close aria-label="Close">&times;</button>

      <div class="reserve-modal__product">
        {primaryImage?.url ? (
          <img class="reserve-modal__img" src={primaryImage.url} alt={primaryImage.alt || product.name} width="80" height="60" />
        ) : (
          <div class="reserve-modal__img reserve-modal__img--placeholder">{categoryLabel}</div>
        )}
        <div class="reserve-modal__info">
          <div class="reserve-modal__name" id="reserveModalTitle">{product.name}</div>
          <div class="reserve-modal__price">Reserve now for <strong>${reservationPrice}</strong></div>
          <div class="reserve-modal__price-sub">${fullRentalPrice}/day total · ${balanceDue} balance on delivery</div>
        </div>
      </div>

      <form class="reserve-form" id="reserveForm" action={FORMSPARK_ACTION} method="POST">
        <input type="hidden" name="_subject" value={`Reservation request — ${product.name}`} />
        <input type="hidden" name="product" value={product.name} />
        <input type="hidden" name="sku" value={product.sku} />
        <input type="hidden" name="reservation_price" value={reservationPrice} />
        <input type="hidden" name="full_rental_price" value={fullRentalPrice} />
        <input type="hidden" name="balance_due_on_delivery" value={balanceDue} />
        <input type="hidden" name="product_url" id="reserveProductUrl" />

        <div class="reserve-form__field">
          <label class="reserve-form__label" for="reserveName">Full Name *</label>
          <input type="text" id="reserveName" name="name" class="reserve-form__input" placeholder="Your full name" required />
        </div>
        <div class="reserve-form__row">
          <div class="reserve-form__field">
            <label class="reserve-form__label" for="reserveEmail">Email *</label>
            <input type="email" id="reserveEmail" name="email" class="reserve-form__input" placeholder="you@example.com" required />
          </div>
          <div class="reserve-form__field">
            <label class="reserve-form__label" for="reservePhone">Phone *</label>
            <input type="tel" id="reservePhone" name="phone" class="reserve-form__input" placeholder="(786) 000-0000" required />
          </div>
        </div>
        <div class="reserve-form__field">
          <label class="reserve-form__label" for="reserveDate">Event Date *</label>
          <input type="date" id="reserveDate" name="event_date" class="reserve-form__input" required />
        </div>

        <button type="submit" class="btn btn--primary btn--full reserve-form__submit">Reserve Now — ${reservationPrice}</button>
        <p class="reserve-form__status" id="reserveStatus" role="status" aria-live="polite" hidden></p>
        <p class="reserve-form__note">You only pay ${reservationPrice} today to lock in your date. The ${balanceDue} balance is paid on delivery.</p>
      </form>
    </div>
  </div>
</Layout>

<script>
  // Image gallery thumbnail switching
  document.querySelectorAll('.pdp__thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      const mainImg = document.getElementById('mainImage') as HTMLImageElement;
      const src = (btn as HTMLElement).dataset.src;
      const alt = (btn as HTMLElement).dataset.alt;
      if (mainImg && src) {
        mainImg.src = src;
        mainImg.alt = alt || '';
      }
      document.querySelectorAll('.pdp__thumb').forEach(t => t.classList.remove('pdp__thumb--active'));
      btn.classList.add('pdp__thumb--active');
    });
  });

  // Star rating interaction
  let selectedRating = 0;
  document.querySelectorAll('.reviews__form-star').forEach(star => {
    star.addEventListener('click', () => {
      const rating = Number((star as HTMLElement).dataset.rating);
      selectedRating = rating;
      const ratingInput = document.getElementById('reviewRating') as HTMLInputElement | null;
      if (ratingInput) ratingInput.value = String(rating);
      document.querySelectorAll('.reviews__form-star').forEach((s, i) => {
        s.textContent = i < rating ? '\u2733' : '\u2734';
        s.textContent = i < rating ? '★' : '☆';
        s.classList.toggle('active', i < rating);
      });
    });
  });

  // ---- Shared: submit a form to Formspark as JSON ----
  function setStatus(el: HTMLElement | null, message: string, ok: boolean) {
    if (!el) return;
    el.textContent = message;
    el.hidden = false;
    el.classList.toggle('is-ok', ok);
    el.classList.toggle('is-error', !ok);
  }

  async function submitFormAsJson(form: HTMLFormElement, statusEl: HTMLElement | null, successMsg: string) {
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const originalText = btn?.textContent || '';
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
    if (statusEl) statusEl.hidden = true;

    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        setStatus(statusEl, successMsg, true);
        form.reset();
        return true;
      }
      setStatus(statusEl, 'Sorry, something went wrong. Please email info@thebigbouncepartyrentals.com.', false);
    } catch {
      setStatus(statusEl, 'Network error — please email info@thebigbouncepartyrentals.com.', false);
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = originalText; }
    }
    return false;
  }

  // ---- Reserve Now modal ----
  const reserveModal = document.getElementById('reserveModal');
  const openReserveBtn = document.getElementById('openReserve');
  const reserveForm = document.getElementById('reserveForm') as HTMLFormElement | null;
  const reserveStatus = document.getElementById('reserveStatus');
  const reserveProductUrl = document.getElementById('reserveProductUrl') as HTMLInputElement | null;

  function openReserve() {
    if (!reserveModal) return;
    if (reserveProductUrl) reserveProductUrl.value = window.location.href;
    reserveModal.hidden = false;
    document.body.style.overflow = 'hidden';
    (document.getElementById('reserveName') as HTMLInputElement | null)?.focus();
  }
  function closeReserve() {
    if (!reserveModal) return;
    reserveModal.hidden = true;
    document.body.style.overflow = '';
  }

  openReserveBtn?.addEventListener('click', openReserve);
  reserveModal?.querySelectorAll('[data-reserve-close]').forEach(el =>
    el.addEventListener('click', closeReserve)
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && reserveModal && !reserveModal.hidden) closeReserve();
  });

  reserveForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    await submitFormAsJson(
      reserveForm,
      reserveStatus,
      "Thank you! Your reservation request has been sent. We'll confirm your date within 2 hours."
    );
  });

  // ---- Review form ----
  const reviewForm = document.getElementById('reviewForm') as HTMLFormElement | null;
  const reviewStatus = document.getElementById('reviewStatus');
  const reviewProductUrl = document.getElementById('reviewProductUrl') as HTMLInputElement | null;

  reviewForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (reviewProductUrl) reviewProductUrl.value = window.location.href;
    if (selectedRating === 0) {
      setStatus(reviewStatus, 'Please select a star rating before submitting.', false);
      return;
    }
    const ok = await submitFormAsJson(reviewForm, reviewStatus, 'Thank you for your review!');
    if (ok) {
      selectedRating = 0;
      document.querySelectorAll('.reviews__form-star').forEach(s => {
        s.textContent = '☆';
        s.classList.remove('active');
      });
    }
  });
</script>

