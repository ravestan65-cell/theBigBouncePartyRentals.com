---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Contact Us" description="Get a free quote for bounce house, water slide, and party equipment rentals. Same day shipping across the USA.">
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>Contact</span></nav>
      <h1 class="page-header__title">Get in Touch</h1>
      <p class="page-header__desc">Ready to book your party rental? We respond within 2 hours!</p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact__inner">
      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2 class="contact-form__heading">Request a Free Quote</h2>
        <p class="contact-form__subheading">Fill out the form and we'll get back to you within 2 hours.</p>

        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group"><label class="form-label" for="name">Full Name *</label><input type="text" id="name" name="name" class="form-input" placeholder="Your full name" required /></div>
            <div class="form-group"><label class="form-label" for="phone">Phone *</label><input type="tel" id="phone" name="phone" class="form-input" placeholder="(786) 000-0000" required /></div>
          </div>
          <div class="form-group"><label class="form-label" for="email">Email *</label><input type="email" id="email" name="email" class="form-input" placeholder="you@example.com" required /></div>
          <div class="form-row">
            <div class="form-group"><label class="form-label" for="event-date">Event Date *</label><input type="date" id="event-date" name="event-date" class="form-input" required /></div>
            <div class="form-group"><label class="form-label" for="event-type">Event Type</label><select id="event-type" name="event-type" class="form-input"><option value="">Select type</option><option value="birthday">Birthday Party</option><option value="school">School Event</option><option value="community">Community Event</option><option value="church">Church Event</option><option value="corporate">Corporate Event</option><option value="other">Other</option></select></div>
          </div>
          <div class="form-group"><label class="form-label" for="products">Products of Interest</label><select id="products" name="products" class="form-input"><option value="">Select category</option><option value="bounce-houses">Bounce Houses</option><option value="water-slides">Water Slides</option><option value="party-accessories">Party Accessories</option><option value="multiple">Multiple Items</option></select></div>
          <div class="form-group"><label class="form-label" for="message">Message</label><textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us about your event..." rows="5"></textarea></div>
          <button type="submit" class="btn btn--primary btn--lg btn--full">Send Quote Request</button>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="contact-sidebar">
        <div class="contact-card">
          <h3 class="contact-card__title">Call Us</h3>
          <a href="tel:+17868181728" class="contact-card__value">(786) 818-1728</a>
          <p class="contact-card__note">Mon-Sun, 7 AM - 7 PM</p>
        </div>
        <div class="contact-card">
          <h3 class="contact-card__title">Email Us</h3>
          <a href="mailto:info@thebigbouncepartyrentals.com" class="contact-card__value">info@thebigbouncepartyrentals.com</a>
          <p class="contact-card__note">We respond within 2 hours</p>
        </div>
        <div class="contact-card">
          <h3 class="contact-card__title">Location</h3>
          <p class="contact-card__value">8810 NW 20 Ave</p>
          <p class="contact-card__note">Miami, Florida 33147</p>
        </div>
        <div class="contact-card">
          <h3 class="contact-card__title">Hours</h3>
          <p class="contact-card__value">Monday - Sunday</p>
          <p class="contact-card__note">7:00 AM - 7:00 PM<br/>24/7 emergency for active bookings</p>
        </div>
        <div class="service-area">
          <h3 class="service-area__title">Service Area</h3>
          <p class="service-area__text">We ship same day across the entire USA:</p>
          <div class="service-area__tags">
            <span>All 50 States</span><span>Same Day Shipping</span><span>Fast Delivery</span><span>Free Shipping on Select Orders</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name');
    alert(`Thank you ${name}! Your quote request has been submitted. We'll get back to you within 2 hours.`);
    form.reset();
  });
</script>

<style>
  .page-header { padding: 6.5rem 0 2rem; background: #fff; border-bottom: 1px solid var(--color-border); }
  .breadcrumb { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; font-size: 0.8rem; color: var(--color-text-lighter); }
  .breadcrumb a { color: var(--color-primary); font-weight: 600; }
  .page-header__title { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.5rem; }
  .page-header__desc { font-size: 1rem; color: var(--color-text-light); max-width: 600px; }

  .contact__inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2.5rem; align-items: start; }

  .contact-form-wrap { background: white; border-radius: var(--radius-md); padding: 2rem; border: 1px solid var(--color-border); }
  .contact-form__heading { font-size: 1.35rem; margin-bottom: 0.35rem; }
  .contact-form__subheading { color: var(--color-text-light); margin-bottom: 1.5rem; font-size: 0.9rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .form-group { margin-bottom: 1rem; }
  .form-label { display: block; font-weight: 600; font-size: 0.8rem; margin-bottom: 0.3rem; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.02em; }
  .form-input { width: 100%; padding: 0.65rem 0.85rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.9rem; transition: border-color var(--transition-fast); background: #FAFAFA; color: var(--color-text); }
  .form-input:focus { outline: none; border-color: var(--color-primary); background: white; }
  .form-input::placeholder { color: var(--color-text-lighter); }
  .form-textarea { resize: vertical; min-height: 100px; }
  select.form-input { cursor: pointer; appearance: auto; }

  .contact-sidebar { display: flex; flex-direction: column; gap: 0.75rem; }
  .contact-card { background: white; border-radius: var(--radius-md); padding: 1.25rem; border: 1px solid var(--color-border); }
  .contact-card__title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-lighter); margin-bottom: 0.2rem; font-weight: 700; }
  .contact-card__value { font-family: var(--font-heading); font-weight: 700; font-size: 1rem; color: var(--color-text); display: block; }
  a.contact-card__value:hover { color: var(--color-primary); }
  .contact-card__note { font-size: 0.75rem; color: var(--color-text-lighter); margin-top: 0.1rem; line-height: 1.4; }

  .service-area { background: var(--color-surface-alt); border-radius: var(--radius-md); padding: 1.25rem; border: 1px solid var(--color-border); }
  .service-area__title { font-size: 0.95rem; margin-bottom: 0.35rem; }
  .service-area__text { font-size: 0.8rem; color: var(--color-text-light); margin-bottom: 0.6rem; }
  .service-area__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .service-area__tags span { background: white; padding: 0.2rem 0.6rem; border-radius: var(--radius-sm); font-size: 0.75rem; font-weight: 600; color: var(--color-primary); border: 1px solid var(--color-border); }

  @media (max-width: 768px) {
    .contact__inner { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 1.25rem; }
    .form-row { grid-template-columns: 1fr; }
    .page-header { padding: 5rem 0 1.5rem; }
    .page-header__title { font-size: 1.5rem; }
  }
  @media (max-width: 480px) {
    .page-header { padding: 4.5rem 0 1.25rem; }
    .contact-form-wrap { padding: 1rem; }
    .contact-form__heading { font-size: 1.1rem; }
    .service-area__tags { gap: 0.3rem; }
    .service-area__tags span { font-size: 0.68rem; padding: 0.15rem 0.5rem; }
  }
</style>
